{
  "name": "salon-module",
  "version": "0.1.0",
  "description": "Salon appointment scheduling module",
  "features": [
    "appointment-scheduling",
    "calendar-view",
    "customer-booking"
  ],
  "permissions": {
    "entities": [
      "appointments",
      "customers",
      "users",
      "payments"
    ],
    "routes": true,
    "jobs": true,
    "events": {
      "publish": [
        "appointment.booked"
      ],
      "subscribe": [
        "appointment.booked",
        "payment.received"
      ]
    }
  }
}
